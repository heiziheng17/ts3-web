# 模拟模式（true=使用假数据预览界面）
MOCK=true

# 网站名称
SITE_NAME=TS3 Web

# TeamSpeak 3 Server Query 配置
TS3_HOST=localhost
TS3_QUERY_PORT=10011
TS3_QUERY_USER=serveradmin
TS3_QUERY_PASS=your_password

# TeamSpeak 3 语音服务器端口
TS3_SERVER_PORT=9987

# Web 界面端口
WEB_PORT=3000

# 客户端下载地址
DOWNLOAD_WINDOWS=https://files.teamspeak-services.com/releases/client/3.6.2/TeamSpeak3-Client-win64-3.6.2.exe
DOWNLOAD_MACOS=https://files.teamspeak-services.com/releases/client/3.6.2/TeamSpeak3-Client-macosx-3.6.2.dmg
DOWNLOAD_LINUX=https://www.teamspeak.com/downloads

# YY频道号（备用方案，留空则不显示）
YY_CHANNEL_ID=

# KOOK频道链接（备用方案，留空则不显示）
KOOK_URL=
